rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Benutzerprofile ──────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Username-Reservierungen (Uniqueness-Index) ───────
    // Dokument-ID = username in Kleinbuchstaben
    // Felder: uid, username (Originalschreibweise), createdAt
    match /usernames/{username} {
      // Jeder eingeloggte Nutzer darf prüfen, ob ein Name vergeben ist
      allow read: if request.auth != null;

      // Erstellen nur, wenn:
      //   1) eingeloggt
      //   2) uid im Dokument == eigene uid
      //   3) Dokument enthält genau die erwarteten Felder
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'username', 'createdAt'])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 30;

      // Kein Überschreiben (verhindert Race-Condition)
      allow update: if false;

      // Löschen nur durch den Eigentümer (für Umbenennungen und Account-Löschung)
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Alles andere: gesperrt ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
